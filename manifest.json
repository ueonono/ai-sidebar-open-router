{
  "manifest_version": 3,
  "name": "AI Sidebar — IA multi-fournisseurs",
  "version": "1.0.0",
  "description": "Sidebar IA open-source type Sider : branchez votre propre IA (Claude, OpenAI, Gemini, Mistral, Groq, DeepSeek, OpenRouter, Ollama/LM Studio local). Lit la page et les onglets, résume, traduit, améliore, génère des images, répond à vos mails, mode agent (sans achat). 100% BYOK, zéro rétention serveur.",
  "author": "Florian Martins",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-sidebar@behivey.com",
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.mistral.ai/*",
    "https://api.groq.com/*",
    "https://api.deepseek.com/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["src/background/background.js"],
    "type": "module"
  },
  "sidebar_action": {
    "default_title": "AI Sidebar",
    "default_panel": "src/sidebar/sidebar.html",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      }
    }
  }
}
